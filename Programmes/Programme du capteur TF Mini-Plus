from machine import I2C, Pin, Timer
import time

# Configuration I2C (Adapter les pins selon votre carte, ex: ESP32)
# SDA: Pin 22, SCL: Pin 23, Fréquence standard 400kHz
i2c = I2C(0, sda=Pin(22), scl=Pin(23), freq=400000)

# Adresse I2C par défaut du TFmini Plus 
TFMINI_ADDR = 0x10

dist1, dist2, dist3, moyenne, error, count = 0, 0, 0, 0, 0, 0
max_error, max_marge, timer_period_ms = 2, 10, 1000

def get_distance():
    try:
        # En I2C, on demande explicitement la trame de données au capteur [cite: 77, 120]
        # Commande pour obtenir les données (9 octets) : 5A 05 00 01 60 
        i2c.writeto(TFMINI_ADDR, b'\x5a\x05\x00\x01\x60')
        
        # Lecture de la réponse de 9 octets 
        data = i2c.readfrom(TFMINI_ADDR, 9)
        
        if len(data) >= 9 and data[0] == 0x59 and data[1] == 0x59:
            # Extraction de la distance (Octets 2 et 3) [cite: 67]
            dist_low = data[2]
            dist_high = data[3]
            distance = dist_low + (dist_high << 8)
            return distance
    except Exception as e:
        print(f"Erreur de lecture I2C: {e}")
    return None

def get_data(timer):
    global max_marge, max_error, dist1, dist2, dist3, moyenne, error, count
    mesure = get_distance()
    
    if mesure is not None:
        # Le capteur renvoie 0 si le signal est trop faible ou hors de portée [cite: 72]
        if 10 < mesure < 1200:
            if abs(mesure - dist1) <= max_marge or error >= max_error:
                dist3 = dist2
                dist2 = dist1
                dist1 = mesure
                moyenne = int((dist1 + dist2 + dist3) / 3)
                error = 0
            else:
                error += 1
            
            count += 1
            print(f"Distance n°{count}: {dist1} cm")
            print(f"Moyenne des 3 dernières: {moyenne} cm | Erreur: {error}\n")
        else:
            count += 1
            print(f"Distance n°{count}: --- Hors limite ---\n")
            
        if error >= max_error:
            print("--- Ajustement suite à erreurs répétées ---\n")

# Initialisation du timer pour la mesure périodique
timer_sensor = Timer(1)
timer_sensor.init(mode=Timer.PERIODIC, period=timer_period_ms, callback=get_data)

while True:
    time.sleep(1)
